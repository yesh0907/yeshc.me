---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import ThemeToggle from './ThemeToggle.astro';
import { site } from '../data/site';

interface Props { jobs: CollectionEntry<'jobs'>[]; projects: CollectionEntry<'featured'>[]; images: Record<string, string>; }
const { jobs, projects, images } = Astro.props;
const jobViews = await Promise.all(jobs.map(async entry => ({ entry, Content: (await render(entry)).Content })));
const projectViews = await Promise.all(projects.map(async entry => ({ entry, Content: (await render(entry)).Content })));
const workbenchNav = [
  { label: 'README.md', href: '#readme' },
  { label: 'experience/', href: '#experience' },
  { label: 'projects/', href: '#projects' },
  { label: 'contact', href: '#contact' },
];
---

<div class="workbench-shell">
  <header>
    <a class="mark" href="#top"><span class="prompt-mark">~/</span>yesh<span class="cursor">_</span></a>
    <nav>{workbenchNav.map(item => <a href={item.href}>{item.label}</a>)}</nav>
    <ThemeToggle />
  </header>

  <main id="content">
    <section class="console" id="top">
      <div class="status"><i></i> Currently building at Harmonic AI</div>
      <div class="hero-copy">
        <p class="prompt"><span class="comment">// currently on main</span><br />~/yesh <span>git status --short</span></p>
        <h1>Builder.<br /><span>Turning ideas into reality.</span></h1>
        <p class="lede">I’m an AI engineer at Harmonic, where I make <a href={site.harmonic}>agents</a> do cool things for VCs.</p>
      </div>
      <div class="readout" aria-label="Quick facts">
        <div><span>Based</span><strong>New York</strong></div>
        <div><span>Focus</span><strong>AI products</strong></div>
        <div><span>Mode</span><strong>Always learning</strong></div>
      </div>
      <a class="scroll" href="#readme">Open README.md ↓</a>
    </section>

    <section class="about" id="readme">
      <div class="section-label"><span>01</span><h2>README.md</h2><p>The short version of how I got here and what I care about building.</p></div>
      <div class="readme-window">
        <div class="editor-tabs" aria-hidden="true">
          <span class="active"><i>MD</i> README.md <b>×</b></span>
          <span><i>TS</i> yesh.ts</span>
        </div>
        <div class="breadcrumbs" aria-hidden="true">yeshc.me <b>›</b> src <b>›</b> content <b>›</b> README.md</div>
        <div class="readme-body">
          <ol aria-hidden="true"><li>1</li><li>2</li><li>3</li><li>4</li><li>5</li><li>6</li><li>7</li><li>8</li></ol>
          <div class="about-copy">
            <p class="readme-heading"># Hello, I’m Yesh.</p>
            {site.about.map(paragraph => <p>{paragraph}</p>)}
            <p class="readme-footer"><span>Currently:</span> building AI products at Harmonic · based in New York</p>
          </div>
        </div>
      </div>
    </section>

    <section class="experience" id="experience">
      <div class="section-label"><span>02</span><h2>experience/</h2><p>Select a directory to inspect the work behind it.</p></div>
      <div class="job-console" data-job-console>
        <div class="console-titlebar"><span>EXPLORER</span><span>•••</span></div>
        <div class="job-tabs" role="tablist" aria-label="Experience">
          <p class="tree-root">⌄ YESH / EXPERIENCE</p>
          {jobViews.map(({ entry }, index) => <button type="button" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-job-tab={index}><span aria-hidden="true">{index === 0 ? '●' : '○'}</span><b>{entry.data.company.toLowerCase().replaceAll(' ', '-')}.md</b><small>{entry.data.range}</small></button>)}
        </div>
        <div class="job-panels">
          {jobViews.map(({ entry, Content }, index) => (
            <article data-job-panel={index} hidden={index !== 0}>
              <p class="path">experience/{entry.data.company.toLowerCase().replaceAll(' ', '-')}</p>
              <h3>{entry.data.title} <a href={entry.data.url}>@ {entry.data.company}</a></h3>
              <p class="location">{entry.data.location} · {entry.data.range}</p>
              <div class="prose-list"><Content /></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="projects" id="projects">
      <div class="section-label"><span>03</span><h2>projects/</h2><p>Things built from a mix of curiosity, useful problems, and questionable amounts of coffee.</p></div>
      <div class="project-grid">
        {projectViews.map(({ entry, Content }, index) => (
          <article class:list={[index === 0 && 'wide']}>
            <div class="card-top"><span>project_0{index + 1}.md</span><a href={entry.data.external || entry.data.github} aria-label={`Open ${entry.data.title}`}>↗</a></div>
            <img src={images[entry.data.title]} alt="" loading="lazy" />
            <h3>{entry.data.title}</h3>
            <div class="description"><Content /></div>
            <ul>{entry.data.tech.map(tech => <li>{tech}</li>)}</ul>
          </article>
        ))}
      </div>
    </section>

    <section class="contact" id="contact">
      <p class="prompt">~/yesh <span>open conversation</span></p>
      <h2>Let’s make something<br /><i>worth talking about.</i></h2>
      <p>{site.email}</p>
      <div><a href={site.github}>GitHub ↗</a><a href={site.linkedin}>LinkedIn ↗</a></div>
    </section>
  </main>
  <footer><span>Yesh Chandiramani © {new Date().getFullYear()}</span><span>Built in small, digestible chunks.</span></footer>
</div>

<script>
  document.querySelectorAll('[data-job-console]').forEach(consoleElement => {
    const tabs = consoleElement.querySelectorAll<HTMLButtonElement>('[data-job-tab]');
    const panels = consoleElement.querySelectorAll<HTMLElement>('[data-job-panel]');
    tabs.forEach(tab => tab.addEventListener('click', () => {
      const selected = tab.dataset.jobTab;
      tabs.forEach(item => item.setAttribute('aria-selected', String(item === tab)));
      panels.forEach(panel => { panel.hidden = panel.dataset.jobPanel !== selected; });
    }));
  });
</script>

<style>
  .workbench-shell { min-height: 100vh; background: var(--page); color: var(--ink); font-family: "Space Grotesk", sans-serif; }
  header { position: sticky; top: 0; z-index: 20; display: flex; align-items: center; gap: 2rem; min-height: 4.75rem; padding: .75rem 2.5vw; border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--page) 92%, transparent); backdrop-filter: blur(16px); }
  .mark { flex: 0 0 auto; font-family: "DM Mono", monospace; font-size: .88rem; font-weight: 500; letter-spacing: -.03em; text-decoration: none; } .prompt-mark, .cursor { color: var(--accent); } .cursor { animation: blink 1.1s steps(1) infinite; }
  nav { display: flex; gap: .25rem; margin-left: auto; } nav a { padding: .55rem .75rem; border-radius: .3rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .67rem; text-decoration: none; } nav a:hover { background: var(--surface); color: var(--ink); }
  header :global(.theme-toggle) { position: relative; flex: 0 0 auto; margin-left: .4rem; border-radius: .45rem; }
  .console { position: relative; display: grid; min-height: 88vh; place-items: center; padding: 8rem 6vw 5rem; border-bottom: 1px solid var(--line); background: radial-gradient(circle at 75% 30%, color-mix(in srgb, var(--accent) 7%, transparent), transparent 30rem); }
  .status { position: absolute; top: 2rem; right: 4vw; padding: .6rem .8rem; border: 1px solid var(--line); background: var(--surface); font-family: "DM Mono", monospace; font-size: .65rem; text-transform: uppercase; } .status i { display: inline-block; width: .55rem; height: .55rem; margin-right: .5rem; border-radius: 50%; background: #45a951; box-shadow: 0 0 0 4px color-mix(in srgb, #45a951 18%, transparent); }
  .hero-copy { width: min(100%, 1000px); }
  .prompt, .path { color: var(--muted); font-family: "DM Mono", monospace; font-size: .72rem; line-height: 1.8; } .prompt span:not(.comment), .path { color: var(--accent); } .comment { color: color-mix(in srgb, var(--muted) 75%, transparent); }
  h1 { margin: 1.5rem 0 2.5rem; font-size: clamp(4rem, 10vw, 9rem); font-weight: 600; letter-spacing: -.075em; line-height: .82; } h1 span { color: transparent; -webkit-text-stroke: 1.5px var(--ink); }
  .lede { max-width: 48rem; margin-left: auto; font-size: clamp(1.2rem, 2vw, 1.6rem); line-height: 1.5; } .lede code { margin-right: .25rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .72em; } .lede a { color: var(--accent); text-decoration-style: wavy; text-underline-offset: 5px; }
  .readout { position: absolute; bottom: 2rem; left: 4vw; display: flex; border: 1px solid var(--line); background: var(--surface); } .readout div { display: grid; gap: .25rem; min-width: 9rem; padding: .8rem 1rem; } .readout div + div { border-left: 1px solid var(--line); } .readout span { color: var(--muted); font-family: "DM Mono", monospace; font-size: .58rem; text-transform: uppercase; } .readout strong { font-size: .78rem; }
  .scroll { position: absolute; right: 4vw; bottom: 2.5rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .68rem; text-decoration: none; }
  .projects, .experience, .about { padding: 8rem 5vw; border-bottom: 1px solid var(--line); }
  .section-label { display: grid; grid-template-columns: 4rem minmax(15rem, 1fr) minmax(15rem, 1fr); gap: 2rem; align-items: start; margin-bottom: 4rem; } .section-label > span { color: var(--accent); font-family: "DM Mono", monospace; } .section-label h2 { margin: 0; font-size: clamp(2.5rem, 5vw, 5rem); letter-spacing: -.055em; line-height: .9; } .section-label p { max-width: 30rem; margin: 0; color: var(--muted); line-height: 1.6; }
  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); } .project-grid article { position: relative; min-width: 0; padding: clamp(1.3rem, 3vw, 2.5rem); border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--surface) 88%, transparent); } .project-grid article.wide { grid-column: 1 / -1; display: grid; grid-template-columns: 1.15fr .85fr; column-gap: 3rem; } .project-grid .wide .card-top, .project-grid .wide img { grid-column: 1; } .project-grid .wide h3, .project-grid .wide .description, .project-grid .wide ul { grid-column: 2; } .project-grid .wide h3 { grid-row: 2; align-self: end; }
  .card-top { display: flex; justify-content: space-between; color: var(--accent); font-family: "DM Mono", monospace; font-size: .65rem; } .card-top a { font-size: 1.4rem; text-decoration: none; }
  .project-grid img { width: 100%; aspect-ratio: 16/9; margin: 1.5rem 0; object-fit: cover; filter: grayscale(.7) contrast(1.05); } .project-grid article:hover img { filter: none; }
  .project-grid h3 { margin: 1rem 0; font-size: clamp(2rem, 4vw, 3.6rem); letter-spacing: -.05em; } .description { color: var(--muted); line-height: 1.55; } .project-grid ul { display: flex; flex-wrap: wrap; gap: .5rem; padding: 0; list-style: none; } .project-grid li { padding: .3rem .55rem; border: 1px solid var(--line); font-family: "DM Mono", monospace; font-size: .58rem; text-transform: uppercase; }
  .job-console { display: grid; grid-template-columns: minmax(15rem, .7fr) 2fr; overflow: hidden; border: 1px solid var(--line); border-radius: .5rem; background: var(--surface); box-shadow: 0 24px 70px rgb(0 0 0 / 12%); } .console-titlebar { grid-column: 1 / -1; display: flex; justify-content: space-between; padding: .65rem 1rem; border-bottom: 1px solid var(--line); color: var(--muted); font-family: "DM Mono", monospace; font-size: .58rem; letter-spacing: .12em; } .job-tabs { display: flex; flex-direction: column; border-right: 1px solid var(--line); } .tree-root { margin: 0; padding: 1rem 1.1rem .55rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .58rem; letter-spacing: .06em; } .job-tabs button { display: grid; grid-template-columns: 1.1rem 1fr; gap: .2rem .45rem; padding: .7rem 1rem .7rem 1.3rem; border: 0; background: transparent; color: var(--ink); cursor: pointer; font: inherit; text-align: left; } .job-tabs button span { grid-row: 1 / 3; color: var(--muted); font-family: "DM Mono", monospace; font-size: .55rem; } .job-tabs button b { overflow: hidden; font-family: "DM Mono", monospace; font-size: .68rem; font-weight: 400; text-overflow: ellipsis; white-space: nowrap; } .job-tabs button small { color: var(--muted); font-size: .58rem; } .job-tabs button[aria-selected="true"] { background: color-mix(in srgb, var(--accent) 18%, var(--surface)); box-shadow: inset 2px 0 var(--accent); } .job-tabs button[aria-selected="true"] span { color: var(--accent); } .job-panels { padding: clamp(2rem, 5vw, 5rem); } .job-panels article[hidden] { display: none; } .job-panels h3 { margin: 1rem 0 .3rem; font-size: clamp(1.8rem, 3vw, 3rem); letter-spacing: -.04em; } .job-panels h3 a { color: var(--accent); text-decoration: none; } .location { color: var(--muted); font-family: "DM Mono", monospace; font-size: .68rem; } .job-panels .prose-list { margin-top: 2rem; color: var(--muted); line-height: 1.65; }
  .about { display: block; } .readme-window { overflow: hidden; max-width: 76rem; margin-left: auto; border: 1px solid var(--line); border-radius: .5rem; background: var(--surface); box-shadow: 0 24px 70px rgb(0 0 0 / 10%); } .editor-tabs { display: flex; border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--page) 65%, var(--surface)); } .editor-tabs > span { display: flex; gap: .6rem; align-items: center; min-width: 11rem; padding: .8rem 1rem; border-right: 1px solid var(--line); color: var(--muted); font-family: "DM Mono", monospace; font-size: .64rem; } .editor-tabs .active { border-top: 2px solid var(--accent); background: var(--surface); color: var(--ink); } .editor-tabs i { color: var(--accent); font-size: .58rem; font-style: normal; font-weight: 700; } .editor-tabs b { margin-left: auto; color: var(--muted); font-weight: 400; } .breadcrumbs { padding: .7rem 1rem; border-bottom: 1px solid var(--line); color: var(--muted); font-family: "DM Mono", monospace; font-size: .6rem; } .breadcrumbs b { margin: 0 .45rem; color: var(--line); } .readme-body { display: grid; grid-template-columns: 3.5rem 1fr; padding: 2.5rem 0 3rem; } .readme-body ol { margin: 0; padding: 0 1.1rem 0 0; border-right: 1px solid var(--line); color: color-mix(in srgb, var(--muted) 60%, transparent); font-family: "DM Mono", monospace; font-size: .7rem; line-height: 2.6; list-style: none; text-align: right; } .about-copy { max-width: 58rem; padding: 0 clamp(1.5rem, 5vw, 5rem); font-size: clamp(1.15rem, 2vw, 1.65rem); line-height: 1.55; } .readme-heading { margin-top: 0; color: var(--accent); font-family: "DM Mono", monospace; font-size: clamp(1.4rem, 3vw, 2.4rem); font-weight: 500; } .readme-footer { margin-top: 2.5rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .72rem; } .readme-footer span { color: var(--accent); }
  .contact { padding: 10rem 6vw 8rem; background: var(--ink); color: var(--page); } .contact h2 { margin: 2rem 0; font-size: clamp(3.5rem, 8vw, 8rem); letter-spacing: -.07em; line-height: .9; } .contact h2 i { color: var(--accent); font-weight: 400; } .contact > p:not(.prompt) { font-family: "DM Mono", monospace; } .contact div { display: flex; gap: 2rem; margin-top: 3rem; }
  footer { display: flex; justify-content: space-between; padding: 2rem 3vw 6rem; color: var(--muted); font-family: "DM Mono", monospace; font-size: .65rem; }
  @keyframes blink { 50% { opacity: 0; } }
  @media (max-width: 760px) { header { gap: 1rem; padding-inline: 1rem; } nav { display: none; } header :global(.theme-toggle) { margin-left: auto; } .console { display: block; min-height: auto; padding-top: 9rem; background: none; } .status { left: 5vw; right: auto; } .readout, .scroll { display: none; } .section-label { grid-template-columns: 1fr; gap: 1rem; } .readme-window { margin: 0; } .editor-tabs > span:not(.active) { display: none; } .readme-body { grid-template-columns: 2.5rem 1fr; } .readme-body ol { padding-right: .75rem; } .about-copy { padding-inline: 1.25rem; } .project-grid { grid-template-columns: 1fr; } .project-grid article.wide { grid-column: auto; display: block; } .job-console { grid-template-columns: 1fr; } .console-titlebar { grid-column: 1; } .job-tabs { flex-direction: row; overflow-x: auto; border-right: 0; border-bottom: 1px solid var(--line); } .tree-root { display: none; } .job-tabs button { min-width: 10rem; border-right: 1px solid var(--line); } footer { flex-direction: column; gap: .5rem; } }
</style>
