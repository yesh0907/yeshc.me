---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Yesh Chandiramani" noindex>
  <main id="content">
    <span>404</span>
    <h1>This page wandered off.</h1>
    <a href="/">Back home →</a>
  </main>
</BaseLayout>

<style>
  main { display: grid; min-height: 100vh; place-content: center; padding: 2rem; text-align: center; }
  span { color: var(--accent); font-family: "DM Mono", monospace; }
  h1 { margin: 1rem 0 2rem; font-family: "Newsreader", serif; font-size: clamp(3rem, 8vw, 7rem); font-weight: 500; letter-spacing: -.05em; }
  a { font-weight: 700; }
</style>
